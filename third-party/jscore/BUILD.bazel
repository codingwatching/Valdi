load("@valdi//bzl:prebuilt_tools.bzl", "jscore_import")

cc_library(
    name = "jscore",
    hdrs = select({
        "//bzl/conditions:macos": {},
        "//conditions:default": glob(["include/**/*.h"]),
    }),
    strip_include_prefix = "include",
    visibility = ["//visibility:public"],
    deps = select({
        "//bzl/conditions:macos": [":jscore_macos"],
        "//conditions:default": [":jscore_library"],
    }),
)

objc_library(
    name = "jscore_macos",
    sdk_frameworks = [
        "JavaScriptCore",
    ],
)

jscore_import(name = "jscore_library")

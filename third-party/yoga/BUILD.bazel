load("//bzl:valdi_library.bzl", "COMMON_COMPILE_FLAGS")

COMPILER_FLAGS = COMMON_COMPILE_FLAGS + [
    "-std=c++20",
    "-Os",  # Always set optimization on
    "-Wno-pedantic",
    "-Wno-sign-compare",
    "-Wno-vla-extension",
    "-fno-exceptions",
    "-Wno-ignored-qualifiers",
    "-Wno-shorten-64-to-32",
    "-Wno-bitwise-instead-of-logical",
    "-Wno-unknown-warning-option",
]

cc_library(
    name = "yoga",
    visibility = ["//visibility:public"],
    deps = [":yoga_cc"] + select({
        "//bzl/conditions:android": [":yoga_android"],
        "//conditions:default": [],
    }),
)

cc_library(
    name = "fbjni",
    srcs = glob([
        "src/android/jni/**/*.cpp",
        "src/android/lyra/**/*.cpp",
    ]),
    hdrs = glob(["src/android/include/**/*.h"]),
    copts = ["-Wno-unreachable-code"],
    includes = ["src/android/include"],
    target_compatible_with = ["@platforms//os:android"],
)

cc_library(
    name = "yoga_cc",
    srcs = glob([
        "src/yoga/**/*.cpp",
    ]),
    hdrs = glob([
        "src/yoga/**/*.h",
        "src/yoga/**/*.hpp",
    ]),
    copts = COMPILER_FLAGS,
    includes = [
        "src/yoga/event",
        "src/yoga/internal",
    ],
    deps = [":yoga_exported_headers"],
)

cc_library(
    name = "yoga_exported_headers",
    hdrs = glob([
        "src/yoga/**/*.h",
        "src/yoga/**/*.hpp",
    ]),
    includes = ["src"],
    tags = ["exported"],
)

cc_test(
    name = "yoga_layout_test",
    srcs = ["test/SubscreenTabsLayout_test.cpp"],
    copts = COMPILER_FLAGS,
    deps = [
        ":yoga",
        "@gtest//:gtest_main",
    ],
)

cc_test(
    name = "yoga_tabs_header_test",
    srcs = ["test/TabsHeaderLayout_test.cpp"],
    copts = COMPILER_FLAGS,
    deps = [
        ":yoga",
        "@gtest//:gtest_main",
    ],
)

cc_test(
    name = "yoga_caption_editor_test",
    srcs = ["test/CaptionEditorLayout_test.cpp"],
    copts = COMPILER_FLAGS,
    deps = [
        ":yoga",
        "@gtest//:gtest_main",
    ],
)

cc_test(
    name = "yoga_style_carousel_test",
    srcs = ["test/StyleCarouselLayout_test.cpp"],
    copts = COMPILER_FLAGS,
    deps = [
        ":yoga",
        "@gtest//:gtest_main",
    ],
)

cc_binary(
    name = "yoga_debug_layout",
    srcs = ["test/debug_layout.cpp"],
    copts = COMPILER_FLAGS,
    deps = [":yoga"],
)

cc_library(
    name = "yoga_android",
    strip_include_prefix = "src/yoga",
    target_compatible_with = ["@platforms//os:android"],
    deps = [
        ":fbjni",
        ":yoga_cc",
    ],
    alwayslink = True,
)
